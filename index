<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เกมแยกขยะด้วย AI พลันตา!</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@tensorflow/tfjs@latest/dist/tf.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@teachablemachine/image@latest/dist/teachablemachine-image.min.js"></script>
    
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f0f4f8;
            font-family: 'Arial', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        h1 {
            color: #2c3e50;
            margin-bottom: 5px;
        }
        p {
            color: #7f8c8d;
            margin-top: 0;
        }
        #canvas-container {
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            background: #fff;
        }
        #loading {
            font-size: 20px;
            color: #e67e22;
            font-weight: bold;
            margin: 20px;
        }
    </style>
</head>
<body>

    <h1>เกมแยกขยะให้ถูกถัง ♻️</h1>
    <p>หยิบขยะมาโชว์หน้ากล้อง แล้วขยับมือให้ตรงกับถังขยะ!</p>
    <div id="loading">กำลังโหลด AI และเปิดกล้อง... กรุณารอสักครู่...</div>
    <div id="canvas-container"></div>

    <script>
        // ลิงก์โมเดล Teachable Machine (เปลี่ยนเป็นลิงก์ของคุณได้ที่นี่)
        // โมเดลนี้สมมติว่ามี Class ชื่อ: "Plastic" (พลาสติก), "Paper" (กระดาษ), "Glass" (แก้ว) และ "Background" (ว่างเปล่า)
        const URL = "https://teachablemachine.withgoogle.com/models/v3_YmN_Wk/"; 
        
        let model, webcam, labelContainer, maxPredictions;
        let currentLabel = "กำลังตรวจสอบ...";
        let score = 0;
        
        // ตัวแปรสำหรับเกม
        let bins = [];
        let currentTrashType = "";
        
        async function initAI() {
            const modelURL = URL + "model.json";
            const metadataURL = URL + "metadata.json";

            // โหลดโมเดล
            model = await tmImage.load(modelURL, metadataURL);
            maxPredictions = model.getTotalClasses();

            // ตั้งค่ากล้องเว็บแคมผ่านโครงสร้างของ Teachable Machine เข้า p5
            document.getElementById('loading').style.display = 'none';
        }

        function setup() {
            // สร้าง Canvas ขนาด 640x480 ไปไว้ใน Container
            let canvas = createCanvas(640, 480);
            canvas.parent('canvas-container');
            
            // เปิดกล้องด้วย p5.js
            webcam = createCapture(VIDEO);
            webcam.size(640, 480);
            webcam.hide(); // ซ่อนตัว preview หลักของ p5 ไว้ เพื่อไปวาดใน canvas เอง

            // เริ่มโหลด AI
            initAI();

            // กำหนดตำแหน่งถังขยะ 3 ประเภท
            bins = [
                { name: "Plastic", color: "#3498db", x: 100, y: 380, w: 100, h: 100, text: "ถังพลาสติก" },
                { name: "Paper", color: "#2ecc71", x: 270, y: 380, w: 100, h: 100, text: "ถังกระดาษ" },
                { name: "Glass", color: "#e74c3c", x: 440, y: 380, w: 100, h: 100, text: "ถังแก้ว" }
            ];
            
            // สุ่มขยะชิ้นแรกที่ผู้เล่นต้องหามาโชว์
            nextTurn();
        }

        function draw() {
            // วาดภาพจากกล้องเว็บแคมลงบน Canvas
            // กลับด้านซ้ายขวาเพื่อให้เหมือนกระจกเงา เล่นง่ายขึ้น
            translate(width, 0);
            scale(-1, 1);
            image(webcam, 0, 0, width, height);
            
            // กลับด้านตัวอักษรกลับมาให้ปกติ
            translate(width, 0);
            scale(-1, 1);

            // วาด UI เกม
            drawGameUI();

            // ส่งภาพไปให้ AI ทาย (ถ้าโหลดโมเดลเสร็จแล้ว)
            if (model) {
                predict();
            }
        }

        async function predict() {
            // ทายผลจาก Canvas
            const prediction = await model.predict(webcam.elt);
            
            // หาอันที่มีความมั่นใจสูงสุด (Probability สูงสุด)
            let highestProb = 0;
            let bestMatch = "Background";
            
            for (let i = 0; i < maxPredictions; i++) {
                if (prediction[i].probability > highestProb) {
                    highestProb = prediction[i].probability;
                    bestMatch = prediction[i].className;
                }
            }

            // ถ้าความมั่นใจมากกว่า 75% ให้ถือว่าเป็นขยะชิ้นนั้น
            if (highestProb > 0.75) {
                currentLabel = bestMatch;
                
                // ตรวจสอบเงื่อนไขการชนะ: ถ้าขยะที่ถืออยู่ ตรงกับขยะที่โจทย์สั่ง
                if (currentLabel === currentTrashType) {
                    score += 10;
                    nextTurn();
                }
            } else {
                currentLabel = "ไม่แน่ใจ...";
            }
        }

        function drawGameUI() {
            // แถบแสดงคะแนนและโจทย์
            fill(0, 0, 0, 150);
            rect(10, 10, 620, 60, 10);
            
            fill(255);
            textSize(20);
            textAlign(LEFT, CENTER);
            text(`คะแนน: ${score}`, 30, 40);
            
            textAlign(RIGHT, CENTER);
            fill("#f1c40f");
            text(`โจทย์: จงหยิบขยะประเภท [ ${getThaiName(currentTrashType)} ]`, 610, 40);

            // วาดถังขยะแต่ละใบ
            for (let bin of bins) {
                fill(bin.color);
                rect(bin.x, bin.y, bin.w, bin.h, 10);
                
                fill(255);
                textSize(16);
                textAlign(CENTER, CENTER);
                text(bin.text, bin.x + bin.w/2, bin.y + bin.h/2);
            }

            // แสดงผลว่าตอนนี้ AI เห็นอะไร
            fill(0, 0, 0, 180);
            rect(10, 100, 220, 40, 5);
            fill(255);
            textSize(16);
            textAlign(LEFT, CENTER);
            text(`AI เห็นเป็น: ${getThaiName(currentLabel)}`, 20, 120);
        }

        function nextTurn() {
            const types = ["Plastic", "Paper", "Glass"];
            currentTrashType = random(types);
        }

        function getThaiName(engName) {
            switch(engName) {
                case "Plastic": return "พลาสติก";
                case "Paper": return "กระดาษ";
                case "Glass": return "แก้ว";
                case "Background": return "อากาศว่างเปล่า";
                default: return engName;
            }
        }
    </script>
</body>
</html>
