<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>เกม AR เก็บขยะแยกถัง</title>
    <script src="https://aframe.io/releases/1.3.0/aframe.min.js"></script>
    <script src="https://raw.githack.com/AR-js-org/AR.js/master/aframe/build/aframe-ar.js"></script>
    <style>
        body { margin: 0; overflow: hidden; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }
        #ui-container {
            position: absolute; top: 10px; left: 10px; z-index: 10;
            color: white; background: rgba(0,0,0,0.6); padding: 15px; border-radius: 10px;
        }
        h1 { margin: 0 0 5px 0; font-size: 20px; }
        p { margin: 3px 0; font-size: 16px; }
        #instruction {
            position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%);
            z-index: 10; color: white; background: rgba(0,0,0,0.7);
            padding: 10px 20px; border-radius: 20px; text-align: center; pointer-events: none;
        }
    </style>
</head>
<body>

    <div id="ui-container">
        <h1>AR แยกขยะ!</h1>
        <p>คะแนน: <span id="score">0</span></p>
        <p>เป้าหมายปัจจุบัน: <span id="target-type" style="font-weight: bold; color: #ffeb3b;">กำลังโหลด...</span></p>
    </div>

    <div id="instruction">
        <p id="instruction-text">ตามหาขยะแล้วแตะเพื่อเก็บให้ตรงถัง!</p>
    </div>

    <a-scene embedded arjs="sourceType: webcam; debugUIEnabled: false;" cursor="rayOrigin: mouse" raycaster="objects: .clickable">
        
        <a-entity camera></a-entity>

        <a-box position="-0.6 -0.5 -2" width="0.4" height="0.6" depth="0.4" color="#1E88E5">
            <a-text value="RECYCLE" align="center" position="0 0.4 0" scale="0.5 0.5 0.5" color="white"></a-text>
        </a-box>
        
        <a-box position="0.6 -0.5 -2" width="0.4" height="0.6" depth="0.4" color="#E53935">
            <a-text value="GENERAL" align="center" position="0 0.4 0" scale="0.5 0.5 0.5" color="white"></a-text>
        </a-box>

        <a-entity id="trash-container"></a-entity>

    </a-scene>

    <script>
        let score = 0;
        let currentTargetType = ""; // ประเภทขยะที่ต้องเก็บในรอบนั้น
        const trashContainer = document.getElementById('trash-container');
        const scoreDisplay = document.getElementById('score');
        const targetDisplay = document.getElementById('target-type');

        // ข้อมูลขยะจำลอง (ในโค้ดนี้ใช้รูปทรงเรขาคณิตแทนไปก่อน)
        const trashTypes = [
            { name: "ขวดพลาสติก", type: "recycle", color: "#64B5F6", geometry: "primitive: cylinder; radius: 0.08; height: 0.25" },
            { name: "กระดาษลัง", type: "recycle", color: "#D7CCC8", geometry: "primitive: box; width: 0.2; height: 0.2; depth: 0.2" },
            { name: "เศษอาหาร/ถุงแกง", type: "general", color: "#81C784", geometry: "primitive: sphere; radius: 0.1" },
            { name: "ซองขนม", type: "general", color: "#FFB74D", geometry: "primitive: cone; radiusBottom: 0.1; height: 0.2" }
        ];

        // สุ่มประเภทขยะที่ผู้เล่นต้องตามเก็บ
        function nextTurn() {
            const types = ["recycle", "general"];
            currentTargetType = types[Math.floor(Math.random() * types.length)];
            targetDisplay.textContent = currentTargetType === "recycle" ? "ขยะรีไซเคิล (ถังสีน้ำเงิน)" : "ขยะทั่วไป (ถังสีแดง)";
            targetDisplay.style.color = currentTargetType === "recycle" ? "#90CAF9" : "#FF8A80";
            
            // สร้างขยะใหม่ขึ้นมา
            spawnTrash();
        }

        // ฟังก์ชันสุ่มสร้างขยะรอบๆ ตัวผู้เล่น
        function spawnTrash() {
            // ลบขยะเก่าออกก่อน
            trashContainer.innerHTML = "";

            // สุ่มเลือกชิ้นขยะจากรายการ
            const trashData = trashTypes[Math.floor(Math.random() * trashTypes.length)];

            const trashElement = document.createElement('a-entity');
            trashElement.setAttribute('geometry', trashData.geometry);
            trashElement.setAttribute('material', `color: ${trashData.color}`);
            trashElement.setAttribute('class', 'clickable');

            // สุ่มตำแหน่งให้อยู่ตรงหน้าผู้เล่น (X: ซ้าย-ขวา, Y: บน-ล่าง, Z: ระยะห่าง)
            const posX = (Math.random() * 1.6) - 0.8; // -0.8 ถึง 0.8
            const posY = (Math.random() * 1) - 0.2;    // -0.2 ถึง 0.8
            const posZ = -(Math.random() * 1 + 1.2);   // -1.2 ถึง -2.2 เมตรข้างหน้า
            trashElement.setAttribute('position', `${posX} ${posY} ${posZ}`);

            // ใส่ข้อความชื่อขยะลอยอยู่เหนือตัวขยะ
            const textElement = document.createElement('a-text');
            textElement.setAttribute('value', trashData.name);
            textElement.setAttribute('align', 'center');
            textElement.setAttribute('position', '0 0.25 0');
            textElement.setAttribute('scale', '0.4 0.4 0.4');
            trashElement.appendChild(textElement);

            // อีเวนต์เมื่อผู้เล่นคลิก/แตะที่ขยะ
            trashElement.addEventListener('click', function () {
                if (trashData.type === currentTargetType) {
                    score += 10;
                    alert(`ถูกต้อง! คุณเก็บ "${trashData.name}" ลงถังได้ถูกต้อง`);
                } else {
                    score -= 5;
                    alert(`ผิดถัง! "${trashData.name}" ไม่ใช่ประเภทที่กำหนด`);
                }
                scoreDisplay.textContent = score;
                nextTurn(); // เริ่มตาถัดไป
            });

            trashContainer.appendChild(trashElement);
        }

        // เริ่มเกมครั้งแรกเมื่อโหลดเสร็จ
        window.onload = () => {
            nextTurn();
        };
    </script>
</body>
</html>
