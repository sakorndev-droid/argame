<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เกมแยกขยะอัจฉริยะ (ตรวจจับสี)</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/p5.js/1.9.4/p5.js"></script>
    
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f4f7f6;
            font-family: 'Kanit', sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
        }
        h1 {
            color: #2c3e50;
            margin-bottom: 5px;
        }
        .instruction {
            color: #555;
            margin-bottom: 15px;
            font-size: 16px;
            text-align: center;
        }
        #canvas-container {
            border-radius: 15px;
            overflow: hidden;
            box-shadow: 0 10px 25px rgba(0,0,0,0.15);
        }
    </style>
</head>
<body>

    <h1>เกมหยิบขยะลงถัง ♻️</h1>
    <div class="instruction">
        <strong>วิธีเล่น:</strong> ดูโจทย์ด้านบน แล้วหยิบวัตถุที่มี <strong>"สี"</strong> ตรงกับถังขยะมาจ่อที่หน้ากล้อง!<br>
        🔵 พลาสติก (สีน้ำเงิน) | 🟢 กระดาษ (สีเขียว) | 🔴 แก้ว/อันตราย (สีแดง)
    </div>
    
    <div id="canvas-container"></div>

    <script>
        let webcam;
        let score = 0;
        let currentTarget = "";
        let detectedColorName = "ไม่พบวัตถุ";
        
        // กำหนดช่วงสีที่จะตรวจจับ (RGB)
        const targets = [
            { name: "Plastic", color: [0, 0, 255], thName: "พลาสติก (สีน้ำเงิน)", hex: "#3498db" },
            { name: "Paper", color: [0, 255, 0], thName: "กระดาษ (สีเขียว)", hex: "#2ecc71" },
            { name: "Glass", color: [255, 0, 0], thName: "แก้ว/อันตราย (สีแดง)", hex: "#e74c3c" }
        ];

        function setup() {
            let canvas = createCanvas(640, 480);
            canvas.parent('canvas-container');
            
            // เปิดกล้องทันที
            webcam = createCapture(VIDEO);
            webcam.size(640, 480);
            webcam.hide();
            
            // สุ่มโจทย์แรก
            nextTurn();
        }

        function draw() {
            // วาดภาพกล้อง (แบบกลับด้านให้เหมือนกระจก จะได้ไม่งงเวลากระดิกมือ)
            translate(width, 0);
            scale(-1, 1);
            image(webcam, 0, 0, width, height);
            translate(width, 0);
            scale(-1, 1);

            // วิเคราะห์สีที่อยู่ "ตรงกลางจอ"
            analyzeCenterColor();

            // วาด UI เกม
            drawUI();
        }

        function analyzeCenterColor() {
            webcam.loadPixels();
            if (webcam.pixels.length > 0) {
                // ดึงค่าสีจากจุดตรงกลางของกล้อง (X: 320, Y: 240)
                let cx = webcam.width / 2;
                let cy = webcam.height / 2;
                let loc = (cx + cy * webcam.width) * 4;
                
                let r = webcam.pixels[loc];
                let g = webcam.pixels[loc+1];
                let b = webcam.pixels[loc+2];

                // วาดเป้าเล็งตรงกลางจอ
                noFill();
                stroke(255, 255, 0);
                strokeWeight(3);
                ellipse(cx, cy, 30, 30);
                fill(r, g, b);
                ellipse(cx, cy, 10, 10);

                // ค้นหาสีที่ใกล้เคียงที่สุด
                let closestMatch = "None";
                let recordDistance = 1000; // ค่าตั้งต้นสูงๆ

                for (let t of targets) {
                    // คำนวณระยะห่างของสี (Color Distance)
                    let d = dist(r, g, b, t.color[0], t.color[1], t.color[2]);
                    if (d < recordDistance && d < 150) { // 150 คือค่าความไวในการตรวจจับ
                        recordDistance = d;
                        closestMatch = t.name;
                    }
                }

                // อัปเดตสถานะสีที่พบ
                if (closestMatch !== "None") {
                    let matchedObj = targets.find(t => t.name === closestMatch);
                    detectedColorName = matchedObj.thName;

                    // ถ้าสีที่อมตรงกับโจทย์ ได้คะแนนทันที!
                    if (closestMatch === currentTarget.name) {
                        score += 10;
                        nextTurn();
                    }
                } else {
                    detectedColorName = "ไม่พบวัตถุสีเด่นชัด";
                }
            }
        }

        function drawUI() {
            // แถบโจทย์บน
            fill(0, 0, 0, 180);
            noStroke();
            rect(10, 10, 620, 60, 10);
            
            fill(255);
            textSize(22);
            textAlign(LEFT, CENTER);
            text(`คะแนน: ${score}`, 30, 40);
            
            textAlign(RIGHT, CENTER);
            fill(currentTarget.hex);
            text(`โจทย์: เอาขยะ [ ${currentTarget.thName} ] มาจ่อตรงกลาง!`, 610, 40);

            // ถังขยะด้านล่างแสดงสัญลักษณ์สี
            let binW = 120;
            let binH = 80;
            let startX = 60;
            
            for (let i = 0; i < targets.length; i++) {
                let t = targets[i];
                fill(t.hex);
                rect(startX + (i * 190), 380, binW, binH, 8);
                
                fill(255);
                textSize(16);
                textAlign(CENTER, CENTER);
                text(t.thName.split(' ')[0], startX + (i * 190) + binW/2, 420);
            }

            // แสดงผลลัพธ์การตรวจจับแบบ Real-time
            fill(0, 0, 0, 150);
            rect(10, 80, 250, 35, 5);
            fill(255);
            textSize(14);
            textAlign(LEFT, CENTER);
            text(`วัตถุตรงเป้าเล็ง: ${detectedColorName}`, 20, 97);
        }

        function nextTurn() {
            // สุ่มประเภทขยะรอบถัดไป
            currentTarget = random(targets);
        }
    </script>
</body>
</html>
